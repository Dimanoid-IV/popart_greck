# Скопируйте в .env.local и подставьте значения.
# Секреты в Git не хранятся — см. SETUP_NEW_MACHINE.md

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=orders@artcanvas.gr
ADMIN_EMAIL=your@email.com

# Платежи (Stripe) — для локальной разработки используйте sk_test_...
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Генерация изображений
NANOBANANA_API_KEY=xxxxxxxx

# Опционально: хостинг изображений
IMGBB_API_KEY=xxxxxxxx
